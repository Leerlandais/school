{% extends 'base.html.twig' %}

{% block head %}
    {{ parent() }}

    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <meta property="og:title" content="Code Snippets by Leerlandais">
    <meta property="og:description" content="A collection of useful code">
    <meta property="og:image" content="https://leerlandais.com/favicon.ico">
    <meta property="og:url" content="https://leerlandais.com">
    <meta property="og:type" content="website">
    {% block stylesheet %}
        <link href="../dist/tailwind.min.css" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css" rel="stylesheet">
    {% endblock %} {# end stylesheets #}
{% endblock %} {# end head #}

{% block title %}School{% endblock %}

{% block mainClass %} 'flex flex-col text-center mx-auto w-full' {% endblock %}
{% block bodyClass %}"bg-gray-200"{% endblock %}
{% block systemMessage %}
    <div id="systemMessageModal"
         class="fixed inset-0 bg-black bg-opacity-50 flex items-start pt-24 justify-center {{ systemMessage ? "" : "hidden" }} z-50">
        <div class="bg-blue-100 rounded-2xl p-6 max-w-lg w-full shadow-2xl relative">
            <button id="closeMessageModal"
                    class="absolute top-3 right-3 text-gray-500 hover:text-gray-800 text-2xl font-bold">
                &times;
            </button>
            <p class="text-base text-gray-700 text-center">
                {{ systemMessage|nl2br }}
            </p>
        </div>
    </div>
{% endblock %}
{% block header %}
    <nav class="bg-blue-500 p-4 flex items-center justify-between">
        <div>
            <a href="./"><h1 class="text-white text-xl font-semibold">English Lessons</h1></a>
        </div>
        <div class="flex items-center space-x-4">

            {% block headerLink %}
                <a href="?route={{ sessionRole ? "admin" : "" }}">
                    <span class="text-white">{{ sessionRole ? "Admin" : "" }}</span>
                </a>
                <a href="?route={{ sessionRole? "logout" : "login" }}">
                    <span class="text-white">{{ sessionRole ? "Logout" : "Login" }}</span>
                </a>
            {% endblock %}
            <i class="fas fa-user-circle text-white text-2xl"></i>
        </div>
    </nav>
{% endblock %} {# end header #}


{% block sideBar %}
    <aside class="bg-gray-800 text-white w-64 min-h-screen p-4">
        <nav>
            <ul class="space-y-2">

                {% for theme in mainThemes %}
                    <li class="option-with-dropdown">

                        <!-- Theme Header -->
                        <div class="dropdown-toggle flex items-center justify-between p-2 hover:bg-gray-700 cursor-pointer">
                            <div class="flex items-center">
                                <i class="fas fa-file-alt mr-2"></i>
                                <span>{{ theme.cat_title }}</span>
                            </div>

                            <i class="fas fa-chevron-down text-xs"></i>
                        </div>

                        <!-- SubThemes -->
                        <ul class="dropdown ml-4 hidden">

                            {% for sub in subThemes %}
                                {% if sub.subcat_parent == theme.cat_id %}

                                    <li class="option-with-dropdown-inner">

                                        <!-- SubTheme Header -->
                                        <div class="dropdown-toggle-inner flex items-center justify-between p-2 hover:bg-gray-700 cursor-pointer">
                                        <span class="ps-4">
                                            {{ sub.subcat_name }}
                                        </span>

                                            <i class="fas fa-chevron-down text-xs"></i>
                                        </div>

                                        <!-- Pages -->
                                        <ul class="dropdown-inner ml-4 hidden">

                                            {# Example pages loop #}
                                            {% for page in pages %}
                                                {% if page.page_subcat == sub.subcat_id %}
                                                    <li>
                                                        <a href="?route=page&id={{ page.page_id }}"
                                                           class="block p-2 hover:bg-gray-700">
                                                            {{ page.page_title }}
                                                        </a>
                                                    </li>
                                                {% endif %}
                                            {% endfor %}

                                        </ul>

                                    </li>

                                {% endif %}
                            {% endfor %}

                        </ul>

                    </li>
                {% endfor %}

            </ul>
        </nav>
    </aside>
{% endblock %} {# end sideBar #}


{% block javascript %}
<script src="{{ PUB_DIR }}scripts/tableSorter.js"></script>
<script src="{{ PUB_DIR }}scripts/sideBarScript.js"></script>
<script src="{{ PUB_DIR }}scripts/systemModalHandler.js"></script>
{% endblock %}