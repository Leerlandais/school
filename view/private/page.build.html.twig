{% extends "template.html.twig" %}
{% block title %}{{ parent() }} | Build{% endblock %}
{% block sideBar %}{% endblock %}
{% block content %}
    {{ dump(pageBlocks) }}
    {% if pageDetails is null %}
        <div class="mt-24">
            <h1 class="head-1-center">This page doesn't exist yet&excl;</h1>
            <h3 class="text-2xl underline"><a href="?route=admin">Home</a></h3>
        </div>
    {% else %}
        <div class="mt-24">
            <h1 class="head-1-center">Building {{ pageDetails.getPageName }}</h1>
        </div>
    {% endif %}
{% endblock %}