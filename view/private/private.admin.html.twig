{% extends "template.html.twig" %}

{% block content %}
    <div class="relative py-12 bg-gradient-to-br from-sky-50 to-gray-200">
        <div class="relative container min-h-screen m-auto px-6 text-gray-500 md:px-12 xl:px-40">
            <div class="m-auto md:w-8/12 lg:w-6/12 xl:w-6/12">
                <div class="rounded-xl bg-white shadow-xl">
                    <div class="p-6 sm:p-16">
                        <div class="mt-6 grid space-y-4">
                            <button class="admin-button-standard">
                                <span class="relative flex items-center space-x-4 justify-center">
                                    <a href="?route=addMainTheme">
                                        <span class="block w-max font-semibold tracking-wide
                                                    text-gray-700 text-sm transition duration-300
                                                    group-hover:text-blue-600 sm:text-base">
                                            Add Main Theme
                                        </span>
                                    </a>
                                </span>
                            </button>
                            <button class="admin-button-standard">
                                <span class="relative flex items-center space-x-4 justify-center">
                                    <a href="?route=addSubTheme">
                                        <span class="block w-max font-semibold tracking-wide
                                                    text-gray-700 text-sm transition duration-300
                                                    group-hover:text-blue-600 sm:text-base">
                                            Add Sub Theme
                                        </span>
                                    </a>
                                </span>
                            </button>
                            <button class="admin-button-standard">
                                <span class="relative flex items-center space-x-4 justify-center">
                                    <a href="?route=addPage">
                                        <span class="block w-max font-semibold tracking-wide
                                                    text-gray-700 text-sm transition duration-300
                                                    group-hover:text-blue-600 sm:text-base">
                                            Add Page
                                        </span>
                                    </a>
                                </span>
                            </button>
                            <button class="admin-button-standard">
                                <span class="relative flex items-center space-x-4 justify-center">
                                    <a href="?route=addNewTag">
                                        <span class="block w-max font-semibold tracking-wide
                                                    text-gray-700 text-sm transition duration-300
                                                    group-hover:text-blue-600 sm:text-base">
                                            Add HTML Tag
                                        </span>
                                    </a>
                                </span>
                            </button>

                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
