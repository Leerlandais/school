{% extends "template.html.twig" %}
{% block title %}{{ parent() }} | Logs{% endblock %}

{% block content %}
<h1 class="h1-default">Logs</h1>
    <div class="flex items-center justify-center">
        <div class="overflow-x-auto">
            <table class="min-w-full bg-white shadow-md rounded-xl">
                <thead>
                <tr class="bg-blue-gray-100 text-center text-gray-700">
                    <th class="py-3 px-4">ID</th>
                    <th class="py-3 px-4">IP</th>
                    <th class="py-3 px-4">Date</th>

                </tr>
                </thead>
                <tbody class="text-blue-gray-900">
                {% for log in logs %}
                    <tr class="border-b border-blue-gray-200">
                        <td class="py-3 px-4">{{ log.getVisitId }}</td>
                        <td class="py-3 px-4">{{ log.getVisitIp }}</td>
                        <td class="py-3 px-4">{{ log.getVisitDate }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

        </div>
    </div>
{% endblock %}